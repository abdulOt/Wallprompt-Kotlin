<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- LEFT ITEM -->
        <LinearLayout
            android:id="@+id/leftImageLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- Image -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/imageLeft"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <!-- Text + Actions row -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/textLeft"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:textSize="14sp"
                    android:maxLines="5"
                    android:fontFamily="@font/poppins_medium" />

                <!-- ACTIONS: Download + Report side-by-side -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start"
                    android:paddingTop="6dp">

                    <ImageButton
                        android:id="@+id/downloadLeft"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/download"
                        android:tooltipText="@string/download"
                        android:importantForAccessibility="yes"
                        android:src="@drawable/download_generate" />

                    <ImageButton
                        android:id="@+id/reportLeft"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/report_content"
                        android:tooltipText="@string/report_content"
                        android:importantForAccessibility="yes"
                        android:src="@drawable/report" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- RIGHT ITEM -->
        <LinearLayout
            android:id="@+id/rightImageLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- Text + Actions row -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/textRight"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:textSize="14sp"
                    android:maxLines="5"
                    android:fontFamily="@font/poppins_medium" />

                <!-- ACTIONS: Download + Report side-by-side -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start"
                    android:paddingTop="6dp">

                    <ImageButton
                        android:id="@+id/downloadRight"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/download"
                        android:tooltipText="@string/download"
                        android:src="@drawable/download_generate" />

                    <ImageButton
                        android:id="@+id/reportRight"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="@string/report_content"
                        android:tooltipText="@string/report_content"
                        android:src="@drawable/report" />
                </LinearLayout>
            </LinearLayout>

            <!-- Image -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/imageRight"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </FrameLayout>
        </LinearLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
