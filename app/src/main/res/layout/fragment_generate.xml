<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/fragment_background"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Settings Button -->
    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="16dp"
        android:adjustViewBounds="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/settings"
        android:padding="8dp"
        android:scaleType="centerInside"
        android:src="@drawable/settings"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/reportButton"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="40dp"
        android:layout_marginStart="16dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/report_content"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:src="@drawable/report"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Main text -->
    <!-- Image Card (not overlapping settings) -->

    <TextView
        android:id="@+id/placeholderText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="252dp"
        android:fontFamily="@font/chewy"
        android:gravity="center"
        android:letterSpacing="0.01"
        android:lineSpacingExtra="4dp"
        android:maxLines="2"
        android:text="@string/fuel_the_art_type_your_vision"
        android:textAlignment="center"
        android:textColor="#2A646A"
        android:textSize="36sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageCard"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/settingsButton"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="2:3"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/loadingPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/loading"
                android:scaleType="centerCrop"
                android:contentDescription="@string/loading_ai_image" />

            <ImageView
                android:id="@+id/generatedImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/generated_image_view"
                android:alpha="0" />

            <ImageButton
                android:id="@+id/downloadButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="16dp"
                android:src="@drawable/download"
                android:contentDescription="@string/download"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:alpha="0" />

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Loading Spinner -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressIndicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminate="true"
        app:indicatorColor="#206420"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/imageCard"
        app:layout_constraintBottom_toBottomOf="@id/imageCard"
        app:layout_constraintStart_toStartOf="@id/imageCard"
        app:layout_constraintEnd_toEndOf="@id/imageCard" />

    <!-- Loading Text -->
    <TextView
        android:id="@+id/loadingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/brewing_your_visual_masterpiece"
        android:textSize="20sp"
        android:textColor="#1D545B"
        android:fontFamily="@font/chewy"
        android:visibility="gone"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/imageCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Input Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="100dp"
        app:cardElevation="12dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundColor="#F5F5F5"
                app:boxCornerRadiusTopStart="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeColor="@android:color/transparent"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/promptEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="1"
                    android:maxLines="5"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:imeOptions="actionSend"
                    android:singleLine="false"
                    android:padding="10dp"
                    android:hint="@string/enter_your_prompt" />

            </com.google.android.material.textfield.TextInputLayout>

            <ImageButton
                android:id="@+id/generateButton"
                android:layout_width="60dp"
                android:layout_height="55dp"
                android:src="@drawable/arrow"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:padding="12dp"
                android:contentDescription="@string/generate" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
